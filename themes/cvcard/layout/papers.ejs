  <meta name="description" content="cvCard - Responsive HTML5 vCard Template">
  <meta name="keywords" content="vcard, html5, portfolio">
  <meta name="author" content="Pixelwars">

  <%- open_graph({twitter_id: theme.twitter, google_plus: theme.google_plus, fb_admins: theme.fb_admins, fb_app_id: theme.fb_app_id, image:page.thumbnail}) %>

  <title><%= page.title %> - Wojtek Erbetowski</title>

  <!-- FAV and TOUCH ICONS -->
