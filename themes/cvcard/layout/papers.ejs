<body>




<!-- CONTAINER -->
<div class="container" id="container">



  <!-- HEADER -->
  <header class="header">

    <!-- NAV MENU -->
    <ul class="vs-nav">

      <!-- InstanceBeginEditable name="Menu-Content" -->

      <li><a href="/"><i title="go to home" class="icon-home-1 tooltip" data-tooltip-pos="right"></i></a></li>

      <!-- InstanceEndEditable -->

    </ul>
    <!-- NAV MENU -->

  </header>
  <!-- HEADER -->





  <!-- WRAPPER -->
  <div class="wrapper">



    <!-- InstanceBeginEditable name="Page-Content" -->





    <!-- .blog-single -->
    <div class="readable-content blog-single ">


      <!-- .hentry -->
      <article class="post type-post format-standard hentry">


        <!-- .entry-header -->
        <header class="entry-header">
          <h1 class="entry-title"><%= page.title %></h1>
        </header>
        <!-- .entry-header -->

        <!-- .entry-content -->
        <div class="entry-content">
          <%- site.pages.filter(function(it){
              return it.path.slice(0, 'papers/'.length) == 'papers/' && it.path != page.path;
          }).map(function(page) {
            return link_to(page.path, page.title) + "<br/>";
          }) %>
        </div>
        <!-- .entry-content -->

      </article>
      <!-- .hentry -->




      <!-- .about-author -->
      <aside class="about-author">

        <h3>WRITTEN BY</h3>

        <!-- .author-bio -->
        <div class="author-bio">

          <!-- .author-img -->
          <div class="author-img">
            <a href="#"><img alt="Wojtek Erbetowski" src="/images/site/avatar.jpg" class="avatar"></a>
          </div>
          <!-- .author-img -->

          <!-- .author-info -->
          <div class="author-info">
            <h4 class="author-name">Wojtek Erbetowski</h4>
            <p>Wojtek is a software developer, community activist, speaker and Head of Engineering at Polidea. He's sharing his ideas, learnings and observations on this blog. Visit <a href="/">main page</a> for more information. </p>
          </div>
          <!-- .author-info -->

        </div>
        <!-- .author-bio -->

      </aside>
      <!-- .about-author -->



    </div>
    <!-- .blog-single -->




    <!-- InstanceEndEditable -->



  </div>
  <!-- WRAPPER -->


</div>
<!-- CONTAINER -->





<!-- InstanceBeginEditable name="Body-End-Content" -->



<!-- InstanceEndEditable -->




